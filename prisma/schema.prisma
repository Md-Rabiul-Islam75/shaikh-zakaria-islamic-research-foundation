generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  name                String
  phone               String   @unique
  password            String
  role                String   @default("student") // student | teacher | admin
  responsibleClasses  String?  // JSON array of class names (for teachers)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Class {
  id          String   @id @default(cuid())
  nameEn      String
  nameBn      String
  description String?
  order       Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Student {
  id                 String         @id @default(cuid())
  studentNameEn      String
  studentNameBn      String?
  fatherName         String
  motherName         String
  dateOfBirth        DateTime
  gender             String
  religion           String
  nationality        String         @default("Bangladeshi")
  bloodGroup         String?
  birthCertificateNo String?
  phone              String
  presentAddress     String
  permanentAddress   String?
  roll               Int            @default(0)
  className          Int
  section            String?
  admissionYear      Int
  admissionFee       String         @default("Free")
  previousSchool     String?
  imageUrl           String?
  imagePublicId      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  classHistory       ClassHistory[]

  @@index([className, admissionYear])
}

model ClassHistory {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  className Int
  session   Int
  roll      Int
  section   String?
  result    String   @default("Promoted")
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([className, session])
}
