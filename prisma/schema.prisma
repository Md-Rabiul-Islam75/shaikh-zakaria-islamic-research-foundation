generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  name                String
  // Phone is unique per source (createdVia). The same phone can appear once
  // per source — e.g. a person can be both an admin-portal login (admin_portal)
  // and a teacher-portal directory entry (teacher_portal) without conflict.
  phone               String
  password            String
  role                String    @default("student") // student | teacher | admin

  // Teacher-specific profile (all optional — filled from Teacher Portal)
  imageUrl            String?
  imagePublicId       String?
  designation         String?   // e.g., Head Teacher, Senior Teacher
  qualification       String?   // e.g., Dawra-e-Hadith, Kamil
  subject             String?   // e.g., Arabic, Quran, Tafsir
  gender              String?
  dateOfBirth         DateTime?
  address             String?
  nidNumber           String?
  joiningDate         DateTime?
  bio                 String?   // short bio
  responsibleClasses  String?   // JSON string array of class IDs

  // Tracks where the account was created. Determines whether the account
  // appears in the Admin Portal "Staff Accounts" list.
  // Values: admin_portal | teacher_portal | self_register | seeded
  createdVia          String?

  activities          ActivityLog[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([phone, createdVia])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userRole   String   // snapshot: student | teacher | admin
  userName   String   // snapshot: user's name at time of action
  action     String   // e.g., CREATE_STUDENT, UPDATE_CLASS, DELETE_TEACHER
  targetType String   // student | teacher | class
  targetId   String?  // id of the target record (may become invalid if deleted)
  targetName String?  // human-readable name for display
  metadata   String?  // optional JSON with extra context
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userRole])
}

model Class {
  id          String    @id @default(cuid())
  nameEn      String
  nameBn      String
  description String?
  order       Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  students    Student[]

  @@index([order])
}

model Student {
  id                 String         @id @default(cuid())
  studentNameEn      String
  studentNameBn      String?
  fatherName         String
  motherName         String
  dateOfBirth        DateTime
  gender             String
  religion           String
  nationality        String         @default("Bangladeshi")
  bloodGroup         String?
  birthCertificateNo String?
  phone              String
  presentAddress     String
  permanentAddress   String?
  roll               Int            @default(0)
  classId            String
  class              Class          @relation(fields: [classId], references: [id])
  section            String?
  admissionYear      Int
  admissionType      String         @default("free") // full_paid | half_paid | free
  admissionFee       String         @default("Free")
  previousSchool     String?
  imageUrl           String?
  imagePublicId      String?
  // Lifecycle: "active" while enrolled, "graduated" after farewell from the
  // final class. Graduated students leave the active roster and appear in the
  // Graduates/Alumni list. classId/admissionYear keep the class they finished.
  status             String         @default("active") // active | graduated
  graduatedAt        DateTime?
  graduatedSession   Int?
  createdById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  classHistory       ClassHistory[]

  @@index([classId, admissionYear])
  @@index([status])
}

model ClassHistory {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classNameEn String
  classNameBn String?
  session    Int
  roll       Int
  section    String?
  result     String   @default("Promoted")
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([session])
}
