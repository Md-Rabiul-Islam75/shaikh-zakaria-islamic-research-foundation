generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  name                String
  phone               String    @unique
  password            String
  role                String    @default("student") // student | teacher | admin

  // Teacher-specific profile (all optional — filled from Teacher Portal)
  imageUrl            String?
  imagePublicId       String?
  designation         String?   // e.g., Head Teacher, Senior Teacher
  qualification       String?   // e.g., Dawra-e-Hadith, Kamil
  subject             String?   // e.g., Arabic, Quran, Tafsir
  gender              String?
  dateOfBirth         DateTime?
  address             String?
  nidNumber           String?
  joiningDate         DateTime?
  bio                 String?   // short bio
  responsibleClasses  String?   // JSON string array of class IDs

  activities          ActivityLog[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userRole   String   // snapshot: student | teacher | admin
  userName   String   // snapshot: user's name at time of action
  action     String   // e.g., CREATE_STUDENT, UPDATE_CLASS, DELETE_TEACHER
  targetType String   // student | teacher | class
  targetId   String?  // id of the target record (may become invalid if deleted)
  targetName String?  // human-readable name for display
  metadata   String?  // optional JSON with extra context
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userRole])
}

model Class {
  id          String    @id @default(cuid())
  nameEn      String
  nameBn      String
  description String?
  order       Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  students    Student[]

  @@index([order])
}

model Student {
  id                 String         @id @default(cuid())
  studentNameEn      String
  studentNameBn      String?
  fatherName         String
  motherName         String
  dateOfBirth        DateTime
  gender             String
  religion           String
  nationality        String         @default("Bangladeshi")
  bloodGroup         String?
  birthCertificateNo String?
  phone              String
  presentAddress     String
  permanentAddress   String?
  roll               Int            @default(0)
  classId            String
  class              Class          @relation(fields: [classId], references: [id])
  section            String?
  admissionYear      Int
  admissionFee       String         @default("Free")
  previousSchool     String?
  imageUrl           String?
  imagePublicId      String?
  createdById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  classHistory       ClassHistory[]

  @@index([classId, admissionYear])
}

model ClassHistory {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classNameEn String
  classNameBn String?
  session    Int
  roll       Int
  section    String?
  result     String   @default("Promoted")
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([session])
}
